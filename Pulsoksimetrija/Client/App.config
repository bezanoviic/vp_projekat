<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
	<system.serviceModel>
		<bindings>
			<netTcpBinding>
				<binding name="ClientBinding" maxReceivedMessageSize="20971520">
					<security mode="None" />
				</binding>
			</netTcpBinding>
		</bindings>
		<client>
			<endpoint name="EcgEndpoint"
					  address="net.tcp://localhost:4000/EcgService"
					  binding="netTcpBinding"
					  bindingConfiguration="ClientBinding"
					  contract="Common.IEcgService" />
		</client>
	</system.serviceModel>
</configuration>